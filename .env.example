# ─────────────────────────────────────────────────────────────
#  Plantilla de variables de entorno.
#  Copia este archivo a `.env` y ajusta si lo necesitas:
#      cp .env.example .env
#
#  Los valores por defecto COINCIDEN con docker-compose.yml,
#  así que el proyecto corre en local sin tocar nada.
# ─────────────────────────────────────────────────────────────

# Puerto donde escucha la API
PORT=3000

# Entorno de ejecución: development | production
NODE_ENV=development

# ── Base de datos (SQL Server) ──────────────────────────────
DB_HOST=localhost
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=Promass@2026
DB_NAME=medical_appointments

# Nivel de log de pino: trace | debug | info | warn | error
LOG_LEVEL=info
